---
import { readFile } from "node:fs/promises";
import CodeBlock from "@/components/reference/CodeBlock.astro";
import Docstring from "@/components/reference/Docstring.astro";
import ReferenceMember from "@/components/reference/Member.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  buildReferenceIndex,
  getMemberId,
  getVisibleMembers,
  parseDocstring,
  type GriffeDump,
  type GriffeMember,
} from "@/lib/griffe";

let dump: GriffeDump | null = null;
let loadError: string | null = null;

try {
  dump = JSON.parse(await readFile("/tmp/dump.json", "utf8")) as GriffeDump;
} catch (error) {
  loadError = error instanceof Error ? error.message : String(error);
}

const modules = dump ? Object.entries(dump) : [];
const [primaryModuleName, primaryModule] = modules[0] ?? [null, null];

function splitMembers(module: GriffeMember | null) {
  const all = module ? getVisibleMembers(module.members) : [];
  return {
    submodules: all.filter(([, m]) => m.kind === "module"),
    classes: all.filter(([, m]) => m.kind === "class"),
    functions: all.filter(([, m]) => m.kind === "function"),
    attributes: all.filter(([, m]) => m.kind === "attribute"),
    aliases: all.filter(([, m]) => m.kind === "alias"),
  };
}

const sections = splitMembers(primaryModule);
const primaryBlocks = parseDocstring(primaryModule?.docstring?.value);
const leadParagraph = primaryBlocks.find((b) => b.type === "paragraph");
const codeExample = primaryBlocks.find((b) => b.type === "code");
const restBlocks = primaryBlocks.filter((b) => b !== leadParagraph && b !== codeExample);

const sidebarGroups = [
  { label: "Submodules", members: sections.submodules },
  { label: "Classes", members: sections.classes },
  { label: "Functions", members: sections.functions },
  { label: "Attributes", members: sections.attributes },
  { label: "Aliases", members: sections.aliases },
].filter((g) => g.members.length > 0);

const allTopLevel = [
  ...sections.classes,
  ...sections.functions,
  ...sections.attributes,
  ...sections.aliases,
  ...sections.submodules,
];
const referenceIndex = dump ? buildReferenceIndex(dump) : undefined;
---

<BaseLayout
  title={`${primaryModuleName ?? "Reference"} — API reference`}
  description="API reference"
  nocredit
>
  <div class="min-h-screen text-[0.9375rem] leading-7 text-slate-900">
    {loadError || !primaryModuleName || !primaryModule ? (
      <div class="mx-auto my-12 max-w-2xl rounded-lg border border-red-200 bg-red-50 p-6 text-[0.9375rem]">
        <strong>Could not load dump.</strong>
        <code class="mt-2 block font-mono text-sm text-red-500">
          {loadError ?? "No modules found in /tmp/dump.json."}
        </code>
      </div>
    ) : (
      <div class="mx-auto grid max-w-[1440px] grid-cols-1 px-4 py-8 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-12 lg:px-8 lg:py-10 xl:grid-cols-[240px_minmax(0,62rem)] xl:gap-16">
        <aside class="hidden lg:sticky lg:top-20 lg:block lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto">
          <div class="pr-4 pb-12">
            <div class="mb-5">
              <a
                href={`#${getMemberId([primaryModuleName])}`}
                class="block font-serif text-xl font-normal leading-tight text-slate-900 no-underline hover:text-[var(--color-accent)]"
              >
                {primaryModuleName}
              </a>
            </div>

            <input
              type="search"
              placeholder="Filter…"
              data-reference-search-input
              class="mb-6 w-full rounded-md border border-gray-200 bg-gray-50 px-2.5 py-1.5 font-sans text-sm text-slate-900 outline-none placeholder:text-gray-400 focus:border-gray-400"
              autocomplete="off"
              spellcheck="false"
            />

            {sidebarGroups.map(({ label, members }) => (
              <div class="mb-5" data-reference-nav-group>
                <div class="mb-1.5 pl-1.5 text-xs font-semibold text-[var(--color-accent)]">
                  {label}
                </div>
                <nav data-reference-nav-group-items>
                  {members.map(([name, member]) => {
                    const children = getVisibleMembers(member.members);
                    return (
                      <div data-reference-nav-item>
                        <a
                          href={`#${getMemberId([primaryModuleName, name])}`}
                          class="block rounded px-1.5 py-1 text-sm leading-6 text-slate-700 no-underline transition hover:bg-red-50 hover:text-[var(--color-accent)]"
                        >
                          {name}
                        </a>
                        {children.length > 0 && (
                          <div class="mb-1.5 ml-3 border-l border-gray-100 pl-2.5">
                            {children.map(([childName]) => (
                              <a
                                href={`#${getMemberId([primaryModuleName, name, childName])}`}
                                class="block py-[0.15rem] font-mono text-[0.8125rem] leading-6 text-slate-500 no-underline hover:text-[var(--color-accent)]"
                              >
                                {childName}
                              </a>
                            ))}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </nav>
              </div>
            ))}

            <div data-reference-empty hidden class="px-1.5 py-2 text-sm text-gray-400">No results.</div>
          </div>
        </aside>

        <main>
          <header
            class="border-b border-gray-200 pb-8"
            id={getMemberId([primaryModuleName])}
            data-reference-entry
            data-reference-search={`${primaryModuleName} ${primaryModule.docstring?.value ?? ""}`}
          >
            <h1 class="mb-3 font-serif text-5xl font-normal leading-none tracking-[-0.01em] text-slate-900">
              {primaryModuleName}
            </h1>
            {leadParagraph?.type === "paragraph" && (
              <p class="mb-5 max-w-[56ch] text-base leading-7 text-slate-600">{leadParagraph.content}</p>
            )}
            {codeExample?.type === "code" && (
              <CodeBlock code={codeExample.content} language={codeExample.language || "python"} large />
            )}
            {restBlocks.length > 0 && (
              <Docstring
                value={restBlocks
                  .map((b) =>
                    b.type === "paragraph" ? b.content : `\`\`\`${b.language}\n${b.content}\n\`\`\``,
                  )
                  .join("\n\n")}
                referenceIndex={referenceIndex}
              />
            )}
          </header>

          <div>
            {allTopLevel.map(([name, member]) => (
              <ReferenceMember
                name={name}
                member={member}
                path={[primaryModuleName, name]}
                root={primaryModule}
                referenceIndex={referenceIndex}
              />
            ))}
          </div>
        </main>
      </div>
    )}
  </div>

  <script is:inline>
    const input = document.querySelector("[data-reference-search-input]");
    const navItems = document.querySelectorAll("[data-reference-nav-item]");
    const navGroups = document.querySelectorAll("[data-reference-nav-group]");
    const entries = document.querySelectorAll("[data-reference-entry]");
    const empty = document.querySelector("[data-reference-empty]");

    if (input instanceof HTMLInputElement) {
      input.addEventListener("input", () => {
        const q = input.value.trim().toLowerCase();
        let navVisible = 0;
        let entryVisible = 0;

        navItems.forEach((item) => {
          const match = !q || (item.textContent ?? "").toLowerCase().includes(q);
          item.toggleAttribute("hidden", !match);
          if (match) navVisible++;
        });

        navGroups.forEach((group) => {
          const items = group.querySelectorAll("[data-reference-nav-item]");
          const hasVisibleItems = [...items].some((item) => !item.hasAttribute("hidden"));
          group.toggleAttribute("hidden", !hasVisibleItems);
        });

        entries.forEach((entry) => {
          const text = entry.getAttribute("data-reference-search")?.toLowerCase() ?? "";
          const match = !q || text.includes(q);
          entry.toggleAttribute("hidden", !match);
          if (match) entryVisible++;
        });

        empty?.toggleAttribute("hidden", !(q && navVisible === 0 && entryVisible === 0));
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "/" && document.activeElement?.tagName !== "INPUT") {
          e.preventDefault();
          input.focus();
          input.select();
        }
        if (e.key === "Escape" && document.activeElement === input) {
          input.value = "";
          input.dispatchEvent(new Event("input"));
          input.blur();
        }
      });
    }
  </script>
</BaseLayout>

<style is:global>
  .ref-depth-1::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 1.125rem;
    height: 1.7rem;
    box-sizing: border-box;
    border-bottom: 1.5px solid #dde1e7;
    border-left: 1.5px solid #dde1e7;
    border-bottom-left-radius: 8px;
  }

  .ref-depth-1:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 0;
    top: 1.7rem;
    bottom: 0;
    border-left: 1.5px solid #dde1e7;
  }

  .ref-depth-2::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 1rem;
    height: 1.625rem;
    box-sizing: border-box;
    border-bottom: 1.5px solid #e9ecef;
    border-left: 1.5px solid #e9ecef;
    border-bottom-left-radius: 6px;
  }

  .ref-depth-2:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 0;
    top: 1.625rem;
    bottom: 0;
    border-left: 1.5px solid #e9ecef;
  }

  .rf-inline-code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: transparent;
    border: 1px solid #e1e4e8;
    border-radius: 4px;
    padding: 0.1em 0.35em;
    color: #24292e;
  }

  .rf-inline-code--link {
    text-decoration: none;
    color: #005cc5;
  }

  .rf-inline-code--link:hover {
    border-color: #cbd5e1;
    color: var(--color-accent);
  }

  .rf-token-keyword { color: #d73a49; }
  .rf-token-function { color: #6f42c1; }
  .rf-token-type { color: #005cc5; }
  .rf-token-string { color: #032f62; }
  .rf-token-number { color: #005cc5; }
  .rf-token-operator { color: #d73a49; }
  .rf-token-decorator { color: #6f42c1; }
  .rf-token-comment {
    color: #6a737d;
    font-style: italic;
  }
</style>
