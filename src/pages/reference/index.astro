---
import { readFile } from "node:fs/promises";
import CodeBlock from "@/components/reference/CodeBlock.astro";
import Docstring from "@/components/reference/Docstring.astro";
import ReferenceMember from "@/components/reference/Member.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getMemberId,
  getVisibleMembers,
  parseDocstring,
  type GriffeDump,
  type GriffeMember,
} from "@/lib/griffe";

let dump: GriffeDump | null = null;
let loadError: string | null = null;

try {
  dump = JSON.parse(await readFile("/tmp/dump.json", "utf8")) as GriffeDump;
} catch (error) {
  loadError = error instanceof Error ? error.message : String(error);
}

const modules = dump ? Object.entries(dump) : [];
const [primaryModuleName, primaryModule] = modules[0] ?? [null, null];

function splitMembers(module: GriffeMember | null) {
  const all = module ? getVisibleMembers(module.members) : [];
  return {
    submodules: all.filter(([, m]) => m.kind === "module"),
    classes: all.filter(([, m]) => m.kind === "class"),
    functions: all.filter(([, m]) => m.kind === "function"),
    attributes: all.filter(([, m]) => m.kind === "attribute"),
    aliases: all.filter(([, m]) => m.kind === "alias"),
  };
}

const sections = splitMembers(primaryModule);
const primaryBlocks = parseDocstring(primaryModule?.docstring?.value);
const leadParagraph = primaryBlocks.find((b) => b.type === "paragraph");
const codeExample = primaryBlocks.find((b) => b.type === "code");
const restBlocks = primaryBlocks.filter((b) => b !== leadParagraph && b !== codeExample);

const sidebarGroups = [
  { label: "Submodules", members: sections.submodules },
  { label: "Classes", members: sections.classes },
  { label: "Functions", members: sections.functions },
  { label: "Attributes", members: sections.attributes },
  { label: "Aliases", members: sections.aliases },
].filter((g) => g.members.length > 0);

const allTopLevel = [
  ...sections.classes,
  ...sections.functions,
  ...sections.attributes,
  ...sections.aliases,
  ...sections.submodules,
];
---

<BaseLayout
  title={`${primaryModuleName ?? "Reference"} — API reference`}
  description="API reference"
  nocredit
>
  <div class="ref-page">
    {loadError || !primaryModuleName || !primaryModule ? (
      <div class="ref-error">
        <strong>Could not load dump.</strong>
        <code>{loadError ?? "No modules found in /tmp/dump.json."}</code>
      </div>
    ) : (
      <div class="ref-layout">

        {/* ── Left sidebar ── */}
        <aside class="ref-sidebar">
          <div class="ref-sidebar-inner">
            <div class="ref-sidebar-mod">
              <a href={`#${getMemberId([primaryModuleName])}`} class="ref-sidebar-modname">
                {primaryModuleName}
              </a>
            </div>

            <input
              type="search"
              placeholder="Filter…"
              data-reference-search-input
              class="ref-search"
              autocomplete="off"
              spellcheck="false"
            />

            {sidebarGroups.map(({ label, members }) => (
              <div class="ref-nav-group">
                <div class="ref-nav-label">{label}</div>
                <nav>
                  {members.map(([name, member]) => {
                    const children = getVisibleMembers(member.members);
                    return (
                      <div data-reference-nav-item>
                        <a
                          href={`#${getMemberId([primaryModuleName, name])}`}
                          class="ref-nav-link"
                        >
                          {name}
                        </a>
                        {children.length > 0 && (
                          <div class="ref-nav-children">
                            {children.map(([childName]) => (
                              <a
                                href={`#${getMemberId([primaryModuleName, name, childName])}`}
                                class="ref-nav-child"
                              >
                                {childName}
                              </a>
                            ))}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </nav>
              </div>
            ))}

            <div data-reference-empty hidden class="ref-no-results">No results.</div>
          </div>
        </aside>

        {/* ── Main content ── */}
        <main class="ref-content">
          <header class="ref-page-header" id={getMemberId([primaryModuleName])} data-reference-entry data-reference-search={`${primaryModuleName} ${primaryModule.docstring?.value ?? ""}`}>
            <h1 class="ref-page-title">{primaryModuleName}</h1>
            {leadParagraph?.type === "paragraph" && (
              <p class="ref-page-lead">{leadParagraph.content}</p>
            )}
            {codeExample?.type === "code" && (
              <CodeBlock code={codeExample.content} language={codeExample.language || "python"} large />
            )}
            {restBlocks.length > 0 && (
              <Docstring
                value={restBlocks
                  .map((b) =>
                    b.type === "paragraph" ? b.content : `\`\`\`${b.language}\n${b.content}\n\`\`\``,
                  )
                  .join("\n\n")}
              />
            )}
          </header>

          <div class="ref-members">
            {allTopLevel.map(([name, member]) => (
              <ReferenceMember
                name={name}
                member={member}
                path={[primaryModuleName, name]}
                root={primaryModule}
              />
            ))}
          </div>
        </main>



      </div>
    )}
  </div>

  <script is:inline>
    const input = document.querySelector("[data-reference-search-input]");
    const navItems = document.querySelectorAll("[data-reference-nav-item]");
    const entries = document.querySelectorAll("[data-reference-entry]");
    const empty = document.querySelector("[data-reference-empty]");

    if (input instanceof HTMLInputElement) {
      input.addEventListener("input", () => {
        const q = input.value.trim().toLowerCase();
        let navVisible = 0;
        let entryVisible = 0;

        navItems.forEach((item) => {
          const match = !q || (item.textContent ?? "").toLowerCase().includes(q);
          item.toggleAttribute("hidden", !match);
          if (match) navVisible++;
        });

        entries.forEach((entry) => {
          const text = entry.getAttribute("data-reference-search")?.toLowerCase() ?? "";
          const match = !q || text.includes(q);
          entry.toggleAttribute("hidden", !match);
          if (match) entryVisible++;
        });

        empty?.toggleAttribute("hidden", !(q && navVisible === 0 && entryVisible === 0));
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "/" && document.activeElement?.tagName !== "INPUT") {
          e.preventDefault();
          input.focus();
          input.select();
        }
        if (e.key === "Escape" && document.activeElement === input) {
          input.value = "";
          input.dispatchEvent(new Event("input"));
          input.blur();
        }
      });
    }
  </script>
</BaseLayout>

<style is:global>
  /* ── Reset global heading styles inside ref-page ── */
  .ref-page h1,
  .ref-page h2,
  .ref-page h3,
  .ref-page h4 {
    font-family: var(--font-sans) !important;
    color: #111827 !important;
    line-height: 1.25 !important;
    margin: 0 !important;
  }

  .ref-page p {
    margin: 0;
  }

  /* ── Page shell ── */
  .ref-page {
    min-height: 100vh;
    color: #111827;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .ref-layout {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1440px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  @media (min-width: 1024px) {
    .ref-layout {
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 3rem;
      padding: 2.5rem 2rem;
      align-items: start;
    }
  }

  @media (min-width: 1280px) {
    .ref-layout {
      grid-template-columns: 240px minmax(0, 62rem);
      gap: 4rem;
    }
  }

  /* ── Left sidebar ── */
  .ref-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .ref-sidebar {
      display: block;
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }

    .ref-sidebar::-webkit-scrollbar { width: 4px; }
    .ref-sidebar::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 2px; }
  }

  .ref-sidebar-inner {
    padding-right: 1rem;
  }

  .ref-sidebar-mod {
    margin-bottom: 1.25rem;
  }

  .ref-sidebar-modname {
    display: block;
    font-size: 1.25rem;
    color: #111827;
    text-decoration: none;
    font-family: var(--font-serif);
    font-weight: normal;
    line-height: 1.2;
  }

  .ref-sidebar-modname:hover { color: var(--color-accent); }

  .ref-search {
    width: 100%;
    padding: 0.4rem 0.6rem;
    font-size: 0.875rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    color: #111827;
    outline: none;
    margin-bottom: 1.5rem;
    font-family: var(--font-sans);
  }

  .ref-search:focus { border-color: #9ca3af; }
  .ref-search::placeholder { color: #9ca3af; }

  .ref-nav-group {
    margin-bottom: 1.25rem;
  }

  .ref-nav-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.375rem;
    padding-left: 0.375rem;
  }

  .ref-nav-link {
    display: block;
    padding: 0.25rem 0.375rem;
    font-size: 0.875rem;
    color: #374151;
    text-decoration: none;
    border-radius: 4px;
    line-height: 1.5;
    transition: color 0.1s, background 0.1s;
  }

  .ref-nav-link:hover { color: var(--color-accent); background: #fef2f2; }

  .ref-nav-children {
    margin-left: 0.75rem;
    border-left: 1px solid #f3f4f6;
    padding-left: 0.625rem;
    margin-bottom: 0.375rem;
  }

  .ref-nav-child {
    display: block;
    padding: 0.15rem 0;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: #6b7280;
    text-decoration: none;
    line-height: 1.6;
  }

  .ref-nav-child:hover { color: var(--color-accent); }

  .ref-no-results {
    font-size: 0.875rem;
    color: #9ca3af;
    padding: 0.5rem 0.375rem;
  }

  /* ── Page header ── */
  .ref-page-header {
    padding-bottom: 2rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 0;
  }

  .ref-page-title {
    font-family: var(--font-serif) !important;
    font-size: 3rem !important;
    font-weight: normal !important;
    letter-spacing: -0.01em;
    color: #111827 !important;
    margin-bottom: 0.75rem !important;
    line-height: 1 !important;
  }

  .ref-page-lead {
    font-size: 1rem;
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    max-width: 56ch;
  }

  /* ── Members list ── */
  .ref-members {
    margin-top: 0;
  }

  /* ── Individual member ── */
  .ref-member {
    scroll-margin-top: 5rem;
  }

  .ref-depth-0 {
    padding: 2rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .ref-depth-0:last-child {
    border-bottom: none;
  }

  .ref-depth-1 {
    position: relative;
    padding: 0.875rem 0 0.875rem 1.75rem;
    margin-top: 0;
  }

  /* └─ curved connector per depth-1 item */
  .ref-depth-1::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 1.125rem;
    height: 1.7rem;
    border-left: 1.5px solid #dde1e7;
    border-bottom: 1.5px solid #dde1e7;
    border-bottom-left-radius: 8px;
    box-sizing: border-box;
  }

  /* vertical continuation line for non-last siblings */
  .ref-depth-1:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 0;
    top: 1.7rem;
    bottom: 0;
    border-left: 1.5px solid #dde1e7;
  }

  .ref-depth-2 {
    position: relative;
    padding: 0.75rem 0 0.75rem 1.5rem;
    margin-top: 0;
  }

  .ref-depth-2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 1rem;
    height: 1.625rem;
    border-left: 1.5px solid #e9ecef;
    border-bottom: 1.5px solid #e9ecef;
    border-bottom-left-radius: 6px;
    box-sizing: border-box;
  }

  .ref-depth-2:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 0;
    top: 1.625rem;
    bottom: 0;
    border-left: 1.5px solid #e9ecef;
  }

  .ref-member-hd {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .ref-member-title {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Kind badge ── */
  .ref-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    vertical-align: baseline;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .ref-badge--class     { background: #eff6ff; color: #2563eb; }
  .ref-badge--function  { background: #f0fdf4; color: #16a34a; }
  .ref-badge--attribute { background: #fff7ed; color: #ea580c; }
  .ref-badge--module    { background: #faf5ff; color: #9333ea; }
  .ref-badge--alias     { background: #f8fafc; color: #64748b; }
  .ref-badge--label     { background: #f1f5f9; color: #475569; }

  /* ── Member headings ── */
  .ref-heading {
    font-size: 1.375rem !important;
    font-weight: 700 !important;
    color: #111827 !important;
    line-height: 1.2 !important;
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .ref-heading--serif {
    font-family: var(--font-serif) !important;
    font-size: 1.75rem !important;
    font-weight: normal !important;
    letter-spacing: -0.01em;
  }

  .ref-heading--sm {
    font-size: 1rem !important;
    font-weight: 600 !important;
  }

  .ref-pilcrow {
    font-size: 0.9em;
    color: #d1d5db;
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.12s;
    font-weight: 400;
  }

  .ref-member-hd:hover .ref-pilcrow,
  .ref-pilcrow:focus {
    opacity: 1;
  }

  /* ── Source link ── */
  .ref-source-link {
    font-size: 0.8125rem;
    color: #9ca3af;
    text-decoration: none;
    white-space: nowrap;
    margin-top: 0.3rem;
    flex-shrink: 0;
  }

  .ref-source-link:hover { color: var(--color-accent); }

  /* ── Signature block ── */
  .ref-sig {
    font-family: var(--font-mono) !important;
    font-size: 0.875rem;
    line-height: 1.6;
    background: transparent;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 0.625rem 1rem;
    margin: 0 0 0.875rem 0;
    overflow-x: auto;
    white-space: pre;
    color: #1e293b;
  }

  /* ── Docstring ── */
  .ref-docstring {
    color: #374151;
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .ref-docstring p {
    margin: 0 0 0.75rem 0;
    max-width: 68ch;
  }

  .ref-docstring p:last-child { margin-bottom: 0; }

  /* ── Children container ── */
  .ref-children {
    margin-top: 0.75rem;
  }

  /* ── Code blocks ── */
  .ref-code-block {
    background: transparent;
    border-radius: 6px;
    overflow: hidden;
    margin: 0.875rem 0;
    border: 1px solid #e1e4e8;
  }

  .ref-code-block pre {
    margin: 0;
    padding: 1rem 1.125rem;
    overflow-x: auto;
    font-family: var(--font-mono) !important;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #24292e;
    white-space: pre;
    word-break: normal;
  }

  .ref-code-block code {
    font-family: inherit;
  }

  .ref-code-block--large pre {
    padding: 1.25rem 1.5rem;
    font-size: 0.9375rem;
  }

  /* ── Inline code ── */
  .rf-inline-code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: transparent;
    border: 1px solid #e1e4e8;
    border-radius: 4px;
    padding: 0.1em 0.35em;
    color: #24292e;
  }

  /* ── Right TOC ── */
  .ref-toc {
    display: none;
  }

  @media (min-width: 1280px) {
    .ref-toc {
      display: block;
      position: sticky;
      top: 5rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }

  .ref-toc-inner {
    padding-left: 1rem;
    border-left: 1px solid #f3f4f6;
  }

  .ref-toc-link {
    display: block;
    font-size: 0.8125rem;
    color: #6b7280;
    text-decoration: none;
    padding: 0.2rem 0;
    line-height: 1.5;
    transition: color 0.1s;
  }

  .ref-toc-link--top {
    color: #374151;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .ref-toc-link:hover { color: var(--color-accent); }

  /* ── Error state ── */
  .ref-error {
    max-width: 40rem;
    margin: 3rem auto;
    padding: 1.5rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    font-size: 0.9375rem;
  }

  .ref-error code {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #ef4444;
  }

  /* ── Syntax tokens — github-light palette ── */
  .rf-token-keyword   { color: #d73a49; } /* red   — from import def while etc */
  .rf-token-function  { color: #6f42c1; } /* purple — name after def            */
  .rf-token-type      { color: #005cc5; } /* blue  — uppercase constants/builtins */
  .rf-token-string    { color: #032f62; } /* dark blue — strings                 */
  .rf-token-number    { color: #005cc5; } /* blue  — numeric literals            */
  .rf-token-operator  { color: #d73a49; } /* red   — =  ->  +  -  etc           */
  .rf-token-decorator { color: #6f42c1; } /* purple — @decorator                */
  .rf-token-comment   { color: #6a737d; font-style: italic; }
</style>
