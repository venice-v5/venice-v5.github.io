---
import Docstring from "@/components/reference/Docstring.astro";
import {
  formatSignature,
  getMemberId,
  getSourceUrl,
  getVisibleMembers,
  renderCodeHtml,
  type GriffeMember,
  type GriffeReferenceIndex,
} from "@/lib/griffe";

interface Props {
  name: string;
  member: GriffeMember;
  path: string[];
  root: GriffeMember;
  referenceIndex?: GriffeReferenceIndex;
  depth?: number;
}

const { name, member, path, root, referenceIndex, depth = 0 } = Astro.props;
const id = getMemberId(path);
const children = getVisibleMembers(member.members);
const signature = formatSignature(name, member);
const signatureHtml = signature ? renderCodeHtml(signature) : null;
const sourceHref = getSourceUrl(member, root);
const labels = (member.labels ?? []).filter(
  (l) => l !== member.kind && l !== "instance-attribute" && l !== "class-attribute",
);
const searchableText = [
  path.join(" "),
  member.kind,
  signature ?? "",
  member.docstring?.value ?? "",
  ...children.map(([n]) => n),
].join(" ");

const depthClass = `ref-depth-${Math.min(depth, 2)}`;
const headingClass =
  depth === 0
    ? "text-[1.75rem] font-normal tracking-[-0.01em]"
    : depth === 1
      ? "text-[1.375rem] font-bold"
      : "text-base font-semibold";
const badgeToneClass = {
  class: "bg-blue-50 text-blue-600",
  function: "bg-green-50 text-green-600",
  attribute: "bg-orange-50 text-orange-600",
  module: "bg-violet-50 text-violet-600",
  alias: "bg-slate-50 text-slate-500",
}[member.kind] ?? "bg-slate-50 text-slate-600";
---

<section
  id={id}
  data-reference-entry
  data-reference-search={searchableText}
  class:list={[
    "ref-member scroll-mt-20",
    depthClass,
    depth === 0 && "border-b border-gray-200 py-8 last:border-b-0",
    depth === 1 && "relative mt-0 py-3.5 pl-7",
    depth >= 2 && "relative mt-0 py-3 pl-6",
  ]}
>
  <div class="group mb-3 flex items-start justify-between gap-4">
    <div class="flex flex-wrap items-center gap-2">
      <span class:list={[
        "inline-block shrink-0 rounded px-1.5 py-[0.15rem] align-baseline font-mono text-[0.7rem] font-medium leading-6",
        badgeToneClass,
      ]}>{member.kind}</span>
      {labels.map((l) => (
        <span class="inline-block shrink-0 rounded bg-slate-100 px-1.5 py-[0.15rem] align-baseline font-mono text-[0.7rem] font-medium leading-6 text-slate-600">
          {l}
        </span>
      ))}
      {depth <= 1 ? (
        <h2 class:list={[
          "inline-flex items-baseline gap-[0.3rem] leading-[1.2] !font-sans text-slate-900",
          headingClass,
        ]}>
          {name}
          <a
            href={`#${id}`}
            class="text-[0.9em] font-normal text-gray-300 opacity-0 transition-opacity duration-100 group-hover:opacity-100 focus:opacity-100"
            aria-label="Link to this section"
          >
            ¶
          </a>
        </h2>
      ) : (
        <h3 class:list={[
          "inline-flex items-baseline gap-[0.3rem] leading-[1.2] !font-sans text-slate-900",
          headingClass,
        ]}>
          {name}
          <a
            href={`#${id}`}
            class="text-[0.9em] font-normal text-gray-300 opacity-0 transition-opacity duration-100 group-hover:opacity-100 focus:opacity-100"
            aria-label="Link to this section"
          >
            ¶
          </a>
        </h3>
      )}
    </div>
    {sourceHref && (
      <a
        href={sourceHref}
        target="_blank"
        rel="noreferrer"
        class="mt-[0.3rem] shrink-0 whitespace-nowrap text-[0.8125rem] text-gray-400 no-underline hover:text-[var(--color-accent)]"
      >
        source ↗
      </a>
    )}
  </div>

  {signatureHtml && (
    <pre class="mb-3.5 overflow-x-auto whitespace-pre rounded-md border border-slate-200 bg-transparent px-4 py-2.5 font-mono text-sm leading-6 text-slate-800"><code set:html={signatureHtml} /></pre>
  )}

  <Docstring value={member.docstring?.value} referenceIndex={referenceIndex} />

  {children.length > 0 && (
    <div class="mt-3">
      {children.map(([childName, childMember]) => (
        <Astro.self
          name={childName}
          member={childMember}
          path={[...path, childName]}
          root={root}
          referenceIndex={referenceIndex}
          depth={depth + 1}
        />
      ))}
    </div>
  )}
</section>
